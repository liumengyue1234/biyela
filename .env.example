# 环境变量配置
# 复制此文件为.env并根据需要修改

# 数据库配置
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=pine_wilt_detection
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_PORT=3306

# 后端配置
BACKEND_PORT=8080
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/pine_wilt_detection?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root
PYTHON_SERVICE_URL=http://python-service:5000

# Python服务配置
PYTHON_SERVICE_PORT=5000
PYTHON_ENV=production
MODEL_DIR=/app/weights
DEVICE=cuda  # 如果有GPU，使用cuda；否则使用cpu

# 前端配置
FRONTEND_DEV_PORT=5173
FRONTEND_PROD_PORT=80

# JWT配置
JWT_SECRET=PineWiltDiseaseDetectionSystemSecretKey2024CTImage
JWT_EXPIRATION=86400000  # 24小时

# 文件上传配置
UPLOAD_PATH=./uploads/
IMAGE_PATH=./uploads/images/
RESULT_PATH=./uploads/results/
REPORT_PATH=./uploads/reports/

# 其他配置
TZ=Asia/Shanghai
