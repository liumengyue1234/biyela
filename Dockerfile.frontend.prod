# 前端Vue.js生产环境的Dockerfile（多阶段构建）
# 第一阶段：构建前端资源
FROM node:16-alpine AS build

WORKDIR /app

# 复制package.json和package-lock.json
COPY package*.json ./

# 安装依赖
RUN npm install

# 复制前端源代码
COPY . .

# 构建生产版本
RUN npm run build

# 第二阶段：使用Nginx托管静态资源
FROM nginx:alpine

# 复制自定义nginx配置
COPY nginx/default.conf /etc/nginx/conf.d/default.conf

# 从构建阶段复制构建好的文件
COPY --from=build /app/dist /usr/share/nginx/html

# 暴露端口
EXPOSE 80

# 启动Nginx
CMD ["nginx", "-g", "daemon off;"]